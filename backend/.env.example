# Ambiente
NODE_ENV=development
PORT=3001

# Banco de Dados (Supabase)
# Copie a connection string do painel do Supabase em:
# Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres

# JWT — TROQUE por uma string longa e aleatória em produção!
# Gere uma: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-essa-chave-secreta-por-uma-string-aleatoria-longa-em-producao

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

